<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- =====================================================
         Phase 1 Permissions: Core Call Screening
         ===================================================== -->

    <!-- Read phone state (detect incoming calls on older APIs) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Answer incoming calls automatically (API 26+) -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Manage our own calls via InCallService -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- Audio: required for TTS greeting playback and microphone foreground service -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service (base) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />

    <!--
         Android 14+ (API 34): Every foreground service type must have a matching
         typed permission declared here. Missing either permission causes an
         IllegalArgumentException / SecurityException at startForegroundService().

         phoneCall  → FOREGROUND_SERVICE_PHONE_CALL  (for CallScreeningService / InCallService)
         microphone → FOREGROUND_SERVICE_MICROPHONE   (for ScreeningForegroundService — TTS listen)
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- System overlay for call screening UI -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Vibration for screening notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Phase 2: Contact lookup for whitelist integration -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Keep the processor from sleeping during active screening -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".CallGuardApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallGuard">

        <!-- =====================================================
             Main Entry Point
             ===================================================== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- =====================================================
             Incoming Call Overlay Activity
             Shown over the lock screen during active screening
             ===================================================== -->
        <activity
            android:name=".ui.IncomingCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            tools:targetApi="27"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.CallGuard.IncomingCall" />

        <!-- =====================================================
             Phase 1 — Core: Call State BroadcastReceiver
             Listens for PHONE_STATE changes on Android 9 and below
             On Android 10+, the InCallService is the preferred path
             ===================================================== -->
        <receiver
            android:name=".screening.CallStateReceiver"
            android:exported="true"
            android:permission="android.permission.READ_PHONE_STATE">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- =====================================================
             Phase 1 — Core: InCallService
             Android 10+ system integration. The system binds to
             this service for every call when CallGuard is the
             default Caller ID & Spam app or default dialer.
             ===================================================== -->
        <!--
             Android 14+: InCallService is bound by the system for active calls.
             foregroundServiceType="phoneCall" is required when targeting API 34+
             so the system knows this service handles telephony.
        -->
        <service
            android:name=".screening.CallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE"
            android:foregroundServiceType="phoneCall"
            tools:ignore="ForegroundServicePermission,Typo">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_RINGING"
                android:value="true" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

        <!-- =====================================================
             Phase 1 — Core: Screening Foreground Service
             Runs persistently while a call is being screened.

             Android 14+ requirement: foregroundServiceType must be explicitly
             declared for EVERY foreground service. Each type listed here must
             have a matching typed permission above:
               • phoneCall  → FOREGROUND_SERVICE_PHONE_CALL
               • microphone → FOREGROUND_SERVICE_MICROPHONE + RECORD_AUDIO
             ===================================================== -->
        <service
            android:name=".screening.ScreeningForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall|microphone"
            tools:ignore="ForegroundServicePermission" />

    </application>

</manifest>
