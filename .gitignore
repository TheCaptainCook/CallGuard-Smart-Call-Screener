# =============================================================================
# CallGuard — Whitelist .gitignore
# Ignore EVERYTHING, then explicitly allow only project source files.
# =============================================================================

# ── Step 1: Ignore everything ──
*

# ── Step 2: Allow directory traversal (required for whitelist) ──
!*/

# ── Step 3: Root project files ──
!.gitignore
!build.gradle
!settings.gradle
!gradle.properties
!gradlew
!gradlew.bat
!README.md
!LICENSE
!CONTRIBUTING.md
!IMPLEMENTED_FEATURES.md

# ── Step 4: Gradle wrapper (properties only, not the jar binary) ──
!gradle/
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.properties
gradle/wrapper/gradle-wrapper.jar

# ── Step 5: App module source & build config ──
!app/
!app/build.gradle
!app/proguard-rules.pro
!app/src/
!app/src/**

# ── Step 6: Force-exclude everything that is NOT project source ──
# Build outputs
**/build/
**/out/
**/bin/
**/gen/

# Gradle caches & daemon
.gradle/
daemon/
wrapper/
caches/
kotlin-profile/

# IDE / editor config
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Android SDK / NDK local files
**/local.properties
.externalNativeBuild/
.cxx/
native/
android/

# Temp files
.tmp/
*.bak
*.tmp
*.swp
*~

# Profiling & logs
captures/
*.log
*.hprof

# Signing secrets
*.jks
*.keystore
keystore.properties

# OS noise
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
