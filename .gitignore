# =============================================================================
# CallGuard - Whitelist-based .gitignore
# This file is configured to exclude everything EXCEPT essential project files.
# =============================================================================

# 1. Ignore everything by default
*

# 2. Allow directories to be scanned (required for whitelist to work)
!*/

# 3. Allow essential project files at the root
!.gitignore
!README.md
!LICENSE
!IMPLEMENTATION_PLAN.md
!CONTRIBUTING.md
!build.gradle
!settings.gradle
!gradlew
!gradlew.bat

# 4. Allow Gradle wrapper configuration (but not the jar)
!gradle/
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.properties
gradle/wrapper/gradle-wrapper.jar

# 5. Allow the main application module
!app/
!app/src/
!app/src/**
!app/build.gradle
!app/proguard-rules.pro

# 6. Explicitly ignore sensitive/local/temporary files (even if in allowed paths)
**/build/
**/local.properties
.gradle/
.idea/
.vscode/
.externalNativeBuild/
.cxx/
daemon/
wrapper/
native/
captures/
*.log
*.hprof
*.jks
*.keystore
keystore.properties
*.bak
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
